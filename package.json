    "@tiptap/starter-kit": "^3.25.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "immer": "^11.1.8",
    "js-base64": "^3.7.8",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
